#!/bin/bash

# Example test script for MCP server
# Copy to test-token.sh and replace with your actual credentials

# IMPORTANT: Never commit the actual test-token.sh file!
# This file is listed in .gitignore

export GSD_AUTH_TOKEN="YOUR_AUTH_TOKEN_HERE"
export GSD_POCKETBASE_URL="https://api.vinny.io"

# Test the connection
curl -s "$GSD_POCKETBASE_URL/api/health" | jq .
