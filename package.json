{
	"name": "gsd-taskmanager",
	"version": "..2",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev",
		"clean": "rimraf .next out",
		"prebuild": "rimraf .next out",
		"build": "node scripts/generate-build-info.cjs && node scripts/update-sw-version.cjs && bash -c 'source .build-env.sh && next build 2>&1 | grep -v baseline-browser-mapping'",
		"start": "next start",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"export": "next export",
		"deploy": "bash scripts/deploy-prod.sh",
		"deploy:dev": "bash scripts/deploy-dev.sh",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:debug": "playwright test --debug",
		"audit": "npx audit-ci --high"
	},
	"dependencies": {
		"@dnd-kit/core": "6.3.1",
		"@dnd-kit/sortable": "10.0.0",
		"@dnd-kit/utilities": "3.2.2",
		"@radix-ui/react-dialog": "1.1.16",
		"@radix-ui/react-dropdown-menu": "2.1.18",
		"@radix-ui/react-icons": "1.3.2",
		"@radix-ui/react-switch": "1.3.1",
		"@radix-ui/react-tooltip": "1.2.10",
		"@sentry/browser": "10.59.0",
		"@tanstack/react-query": "5.101.0",
		"@tanstack/react-virtual": "3.14.3",
		"canvas-confetti": "1.9.4",
		"clsx": "2.1.1",
		"cmdk": "1.1.1",
		"date-fns": "4.4.0",
		"dexie": "4.4.4",
		"dexie-react-hooks": "4.4.0",
		"lucide-react": "1.21.0",
		"nanoid": "5.1.14",
		"next": "16.2.9",
		"next-themes": "0.4.6",
		"pocketbase": "0.27.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"recharts": "3.8.1",
		"sonner": "2.0.7",
		"tailwind-merge": "3.6.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.0",
		"@tailwindcss/postcss": "4.3.1",
		"@testing-library/dom": "10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/canvas-confetti": "1.9.0",
		"@types/node": "26.0.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"@vitest/coverage-v8": "4.1.9",
		"babel-plugin-react-compiler": "1.0.0",
		"eslint": "10.5.0",
		"eslint-config-next": "16.2.9",
		"eslint-plugin-react-hooks": "7.1.1",
		"fake-indexeddb": "6.2.5",
		"jsdom": "29.1.1",
		"postcss": "8.5.15",
		"rimraf": "6.1.3",
		"tailwindcss": "4.3.1",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "4.1.9"
	},
	"workspaces": [
		"packages/*"
	],
	"overrides": {
		"@hono/node-server": ">=1.19.13",
		"js-yaml": ">=4.1.1",
		"baseline-browser-mapping": "2.9.11",
		"esbuild": ">=0.25.0",
		"@radix-ui/react-dialog": "1.1.16",
		"@isaacs/brace-expansion": ">=5.0.1",
		"brace-expansion": ">=5.0.6",
		"qs": ">=6.15.2",
		"minimatch": ">=3.1.3",
		"rollup": ">=4.59.0",
		"hono": ">=4.12.21",
		"undici": ">=7.24.0",
		"flatted": ">=3.4.2",
		"express-rate-limit": ">=8.2.2",
		"path-to-regexp": ">=8.4.0",
		"picomatch": ">=4.0.4",
		"fast-uri": ">=3.1.2",
		"ip-address": ">=10.2.0",
		"postcss": ">=8.5.14"
	},
	"license": "MIT"
}
