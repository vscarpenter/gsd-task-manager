# Build artifacts
.next/
out/

# Dependencies (reinstalled inside Docker)
node_modules/
packages/*/node_modules/

# Version control
.git/
.gitignore

# Tests & docs (not needed for production build)
tests/
docs/
coverage/
test_output.txt

# Environment & secrets
.env
.env.local
.env.*.local
.build-env.sh
.build-info.json
.npmrc
bunfig.toml

# Certificates & keys (never copy into build context)
*.pem
*.key
*.crt
*.p12
*.pfx
*.cert
certs/
docker/certs/

# Editor & OS files
.vscode/
.idea/
*.swp
.DS_Store

# Other sensitive / unnecessary files
*.secret
*.secrets
credentials*
.terraform/
*.tfstate*
sonar-project.properties
